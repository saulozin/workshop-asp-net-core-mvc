@model SallesWebMvc.Models.SalesRecord

@{
    ViewData["Title"] = "Sale Details";
}

<h2>@ViewData["Title"]</h2>

<hr />

<dl class="row">

    <dt class="col-sm-2">
        Date
    </dt>

    <dd class="col-sm-10">
        @Model.Date.ToString("dd/MM/yyyy")
    </dd>

    <dt class="col-sm-2">
        Amount
    </dt>

    <dd class="col-sm-10">
        @Model.Amount.ToString("F2")
    </dd>

    <dt class="col-sm-2">
        Status
    </dt>

    <dd class="col-sm-10">
        @Model.Status
    </dd>

    <dt class="col-sm-2">
        Seller
    </dt>

    <dd class="col-sm-10">
        @Model.Seller.Name
    </dd>

    <dt class="col-sm-2">
        Department
    </dt>

    <dd class="col-sm-10">
        @Model.Seller.Department.Name
    </dd>

</dl>

<div>
    <a asp-action="Edit"
       asp-route-id="@Model.Id"
       class="btn btn-primary">
        Edit
    </a>

    <a asp-action="SimpleSearch"
       class="btn btn-secondary">
        Back
    </a>
</div>
